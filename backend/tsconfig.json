{
  "compilerOptions": {
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
  },
  "watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "dist"
    ]
  }
}